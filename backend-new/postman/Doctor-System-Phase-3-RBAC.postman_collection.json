{
  "info": {
    "name": "Doctor System - Phase 3 RBAC",
    "description": "Sprint 2 RBAC foundation collection for backend-new. Run Auth login first so Postman's cookie jar has access_token and refresh_token cookies, then set csrfToken from the csrf_token cookie or Auth collection variable.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "List Permissions",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/v1/rbac/permissions",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "rbac", "permissions"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 200', function () { pm.response.to.have.status(200); });",
              "const json = pm.response.json();",
              "pm.test('success envelope', function () { pm.expect(json.success).to.eql(true); });",
              "pm.test('permissions returned', function () { pm.expect(json.data.permissions).to.be.an('array'); });"
            ]
          }
        }
      ]
    },
    {
      "name": "List Roles",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/v1/rbac/roles",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "rbac", "roles"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 200', function () { pm.response.to.have.status(200); });",
              "const json = pm.response.json();",
              "pm.test('roles returned', function () { pm.expect(json.data.roles).to.be.an('array'); });"
            ]
          }
        }
      ]
    },
    {
      "name": "Create Role",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "x-csrf-token",
            "value": "{{csrfToken}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Billing Manager\",\n  \"code\": \"billing_manager\",\n  \"description\": \"Can access current-user baseline and future billing workflows.\",\n  \"permissions\": [\n    {\n      \"key\": \"users.me.read\",\n      \"scope\": \"CLINIC\"\n    }\n  ]\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/rbac/roles",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "rbac", "roles"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 201', function () { pm.response.to.have.status(201); });",
              "const json = pm.response.json();",
              "pm.test('no raw secrets in response', function () { pm.expect(pm.response.text()).to.not.include('access_token'); });",
              "if (pm.response.code === 201) { pm.environment.set('roleId', json.data.role.id); }"
            ]
          }
        }
      ]
    },
    {
      "name": "Assign User Role",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "x-csrf-token",
            "value": "{{csrfToken}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"clinicId\": \"{{clinicId}}\",\n  \"userId\": \"{{targetUserId}}\",\n  \"roleId\": \"{{roleId}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/rbac/user-roles",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "rbac", "user-roles"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 200 or 201', function () { pm.expect([200, 201]).to.include(pm.response.code); });",
              "const json = pm.response.json();",
              "pm.test('assignment returned', function () { pm.expect(json.data.assignment).to.have.property('id'); });",
              "pm.environment.set('roleAssignmentId', json.data.assignment.id);"
            ]
          }
        }
      ]
    },
    {
      "name": "Revoke User Role",
      "request": {
        "method": "DELETE",
        "header": [
          {
            "key": "x-csrf-token",
            "value": "{{csrfToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/rbac/user-roles/{{roleAssignmentId}}?clinicId={{clinicId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "rbac", "user-roles", "{{roleAssignmentId}}"],
          "query": [
            {
              "key": "clinicId",
              "value": "{{clinicId}}",
              "description": "Required for platform users; ignored for clinic users."
            }
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 200', function () { pm.response.to.have.status(200); });",
              "const json = pm.response.json();",
              "pm.test('assignment revoked', function () {",
              "  pm.expect(json.success).to.eql(true);",
              "  pm.expect(json.data.assignment.revoked).to.eql(true);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Current User Profile",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/v1/users/me",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "users", "me"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 200', function () { pm.response.to.have.status(200); });",
              "const json = pm.response.json();",
              "pm.test('current user returned', function () {",
              "  pm.expect(json.message).to.eql('Current user');",
              "  pm.expect(json.data.user).to.have.property('id');",
              "  pm.expect(json.data.access.permissions).to.be.an('array');",
              "  pm.expect(json.data.access.scopedPermissions).to.be.an('object');",
              "});"
            ]
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "clinicId",
      "value": "22222222-2222-4222-8222-222222222222"
    },
    {
      "key": "targetUserId",
      "value": "11111111-1111-4111-8111-111111111111"
    },
    {
      "key": "roleId",
      "value": ""
    },
    {
      "key": "roleAssignmentId",
      "value": ""
    },
    {
      "key": "csrfToken",
      "value": ""
    }
  ]
}
