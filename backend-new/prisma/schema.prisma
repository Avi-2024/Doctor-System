generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model schema_migrations {
  name        String   @id @db.VarChar(190)
  executed_at DateTime @default(now())
}

model audit_logs {
  id            String   @id @db.Char(36)
  clinic_id     String?  @db.Char(36)
  actor_user_id String?  @db.Char(36)
  action        String   @db.VarChar(120)
  module_name   String   @db.VarChar(120)
  resource_type String   @db.VarChar(120)
  resource_id   String?  @db.Char(36)
  severity      String   @default("INFO") @db.VarChar(30)
  request_id    String?  @db.VarChar(128)
  correlation_id String? @db.Char(36)
  ip_address    String?  @db.VarChar(64)
  user_agent    String?  @db.VarChar(512)
  before_data   Json?
  after_data    Json?
  metadata      Json?
  hash          String?  @db.Char(64)
  previous_hash String?  @db.Char(64)
  created_at    DateTime @default(now())

  @@index([clinic_id, created_at])
  @@index([clinic_id, module_name, action, created_at])
  @@index([clinic_id, resource_type, resource_id])
  @@index([actor_user_id])
  @@index([request_id])
  @@index([correlation_id])
}

model audit_chain_state {
  chain_scope String   @id @db.VarChar(190)
  latest_hash String?  @db.Char(64)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
}

model clinics {
  id                         String                 @id @db.Char(36)
  code                       String                 @unique @db.VarChar(80)
  name                       String                 @db.VarChar(190)
  status                     String                 @default("ACTIVE") @db.VarChar(40)
  timezone                   String                 @default("UTC") @db.VarChar(80)
  contact                    Json?
  address                    Json?
  branding                   Json?
  owner_user_id              String?                @db.Char(36)
  onboarding_idempotency_key String?                @unique @db.VarChar(190)
  onboarding_payload_hash    String?                @db.Char(64)
  created_by                 String?                @db.Char(36)
  updated_by                 String?                @db.Char(36)
  deleted_by                 String?                @db.Char(36)
  is_deleted                 Boolean                @default(false)
  created_at                 DateTime               @default(now())
  updated_at                 DateTime               @updatedAt
  deleted_at                 DateTime?
  archived_at                DateTime?
  owner_user                 users?                 @relation("clinic_owner", fields: [owner_user_id], references: [id], onDelete: SetNull, onUpdate: Cascade)
  users                      users[]                @relation("clinic_users")
  branches                   clinic_branches[]
  settings                   settings[]             @relation("clinic_settings")
  setting_history            setting_history[]      @relation("clinic_setting_history")
  invitations                user_invitations[]
  subscriptions              clinic_subscriptions[]
  roles                      roles[]                @relation("clinic_roles")
  role_permissions           role_permissions[]     @relation("clinic_role_permissions")
  user_roles                 user_roles[]           @relation("clinic_user_roles")
  branch_assignments         user_branch_assignments[]
  refresh_tokens             refresh_tokens[]       @relation("clinic_refresh_tokens")
  password_reset_tokens      password_reset_tokens[] @relation("clinic_password_reset_tokens")
  login_attempts             login_attempts[]       @relation("clinic_login_attempts")
  account_lockouts           account_lockouts[]     @relation("clinic_account_lockouts")
  patient_code_counters      patient_code_counters[]
  patient_registration_requests patient_registration_requests[]
  patients                   patients[]
  patient_records            patient_records[]

  @@index([status, is_deleted])
  @@index([owner_user_id])
  @@index([created_at])
  @@index([updated_at])
}

model patient_code_counters {
  id          String   @id @db.Char(36)
  clinic_id   String   @db.Char(36)
  counter_key String   @db.VarChar(80)
  next_value  Int      @default(1)
  created_by  String?  @db.Char(36)
  updated_by  String?  @db.Char(36)
  is_deleted  Boolean  @default(false)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
  clinic      clinics  @relation(fields: [clinic_id], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([clinic_id, counter_key])
  @@index([clinic_id, updated_at])
}

model patient_registration_requests {
  id              String    @id @db.Char(36)
  clinic_id       String    @db.Char(36)
  idempotency_key String    @db.VarChar(190)
  request_hash    String    @db.Char(64)
  patient_id      String?   @db.Char(36)
  status          String    @default("IN_PROGRESS") @db.VarChar(40)
  response_summary Json?
  created_by      String?   @db.Char(36)
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt
  clinic          clinics   @relation(fields: [clinic_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
  patient         patients? @relation(fields: [patient_id], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@unique([clinic_id, idempotency_key])
  @@index([clinic_id, patient_id])
  @@index([clinic_id, status, created_at])
}

model patients {
  id               String    @id @db.Char(36)
  clinic_id        String    @db.Char(36)
  patient_code     String    @db.VarChar(80)
  full_name        String    @db.VarChar(190)
  normalized_name  String?   @db.VarChar(190)
  phone            String?   @db.VarChar(40)
  normalized_phone String?   @db.VarChar(40)
  email            String?   @db.VarChar(190)
  normalized_email String?   @db.VarChar(190)
  gender           String?   @db.VarChar(40)
  date_of_birth    DateTime?
  blood_group      String?   @db.VarChar(20)
  demographics     Json?
  medical_summary  Json?
  status           String    @default("ACTIVE") @db.VarChar(40)
  archived_at      DateTime?
  archived_by      String?   @db.Char(36)
  created_by       String?   @db.Char(36)
  updated_by       String?   @db.Char(36)
  deleted_by       String?   @db.Char(36)
  is_deleted       Boolean   @default(false)
  created_at       DateTime  @default(now())
  updated_at       DateTime  @updatedAt
  deleted_at       DateTime?
  clinic           clinics   @relation(fields: [clinic_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
  records          patient_records[]
  registration_requests patient_registration_requests[]

  @@unique([clinic_id, patient_code])
  @@index([clinic_id, is_deleted, created_at])
  @@index([clinic_id, status, is_deleted])
  @@index([clinic_id, updated_at])
  @@index([clinic_id, normalized_phone, is_deleted])
  @@index([clinic_id, normalized_email, is_deleted])
  @@index([clinic_id, normalized_name])
  @@index([clinic_id, normalized_name, date_of_birth, is_deleted])
}

model patient_records {
  id               String    @id @db.Char(36)
  clinic_id        String    @db.Char(36)
  patient_id       String    @db.Char(36)
  record_type      String    @db.VarChar(80)
  title            String    @db.VarChar(190)
  record_data      Json
  recorded_at      DateTime  @default(now())
  attachment_count Int       @default(0)
  status           String    @default("ACTIVE") @db.VarChar(40)
  archived_at      DateTime?
  archived_by      String?   @db.Char(36)
  created_by       String?   @db.Char(36)
  updated_by       String?   @db.Char(36)
  deleted_by       String?   @db.Char(36)
  is_deleted       Boolean   @default(false)
  created_at       DateTime  @default(now())
  updated_at       DateTime  @updatedAt
  deleted_at       DateTime?
  clinic           clinics   @relation(fields: [clinic_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
  patient          patients  @relation(fields: [patient_id], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([clinic_id, patient_id, created_at])
  @@index([clinic_id, record_type, recorded_at])
  @@index([clinic_id, status, is_deleted])
  @@index([clinic_id, updated_at])
}

model clinic_branches {
  id                 String                    @id @db.Char(36)
  clinic_id          String                    @db.Char(36)
  branch_code        String                    @db.VarChar(80)
  name               String                    @db.VarChar(190)
  timezone           String                    @default("UTC") @db.VarChar(80)
  contact            Json?
  address            Json?
  is_primary         Boolean                   @default(false)
  primary_branch_key String?                   @unique @db.VarChar(120)
  status             String                    @default("ACTIVE") @db.VarChar(40)
  created_by         String?                   @db.Char(36)
  updated_by         String?                   @db.Char(36)
  deleted_by         String?                   @db.Char(36)
  is_deleted         Boolean                   @default(false)
  created_at         DateTime                  @default(now())
  updated_at         DateTime                  @updatedAt
  deleted_at         DateTime?
  clinic             clinics                   @relation(fields: [clinic_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
  settings           settings[]
  branch_assignments user_branch_assignments[]

  @@unique([clinic_id, branch_code])
  @@index([clinic_id, is_deleted])
  @@index([clinic_id, status, is_deleted])
  @@index([clinic_id, is_primary, is_deleted])
  @@index([clinic_id, updated_at])
  @@index([clinic_id, name])
}

model settings {
  id                 String            @id @db.Char(36)
  clinic_id          String?           @db.Char(36)
  branch_id          String?           @db.Char(36)
  user_id            String?           @db.Char(36)
  setting_key        String            @db.VarChar(160)
  value              Json
  scope              String            @db.VarChar(40)
  is_encrypted       Boolean           @default(false)
  status             String            @default("ACTIVE") @db.VarChar(40)
  active_setting_key String?           @unique @db.VarChar(255)
  created_by         String?           @db.Char(36)
  updated_by         String?           @db.Char(36)
  deleted_by         String?           @db.Char(36)
  is_deleted         Boolean           @default(false)
  created_at         DateTime          @default(now())
  updated_at         DateTime          @updatedAt
  deleted_at         DateTime?
  clinic             clinics?          @relation("clinic_settings", fields: [clinic_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
  branch             clinic_branches?  @relation(fields: [branch_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
  user               users?            @relation("user_settings", fields: [user_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
  history            setting_history[]

  @@index([clinic_id, setting_key, is_deleted])
  @@index([clinic_id, updated_at])
  @@index([clinic_id, branch_id, scope, is_deleted])
  @@index([clinic_id, user_id, scope, is_deleted])
  @@index([scope, setting_key])
}

model setting_history {
  id           String    @id @db.Char(36)
  setting_id   String    @db.Char(36)
  clinic_id    String?   @db.Char(36)
  setting_key  String    @db.VarChar(160)
  scope        String    @db.VarChar(40)
  before_value Json?
  after_value  Json?
  changed_by   String?   @db.Char(36)
  change_reason String?  @db.VarChar(500)
  created_at   DateTime  @default(now())
  setting      settings  @relation(fields: [setting_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
  clinic       clinics?  @relation("clinic_setting_history", fields: [clinic_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
  changed_by_user users? @relation("setting_changed_by", fields: [changed_by], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([clinic_id, setting_key, created_at])
  @@index([clinic_id, changed_by, created_at])
  @@index([setting_id, created_at])
}

model user_invitations {
  id                    String    @id @db.Char(36)
  clinic_id             String    @db.Char(36)
  user_id               String?   @db.Char(36)
  email                 String    @db.VarChar(190)
  full_name             String    @db.VarChar(190)
  token_hash            String    @unique @db.Char(64)
  active_invitation_key String?   @unique @db.VarChar(255)
  status                String    @default("PENDING") @db.VarChar(40)
  invited_by            String?   @db.Char(36)
  expires_at            DateTime
  accepted_at           DateTime?
  revoked_at            DateTime?
  revoked_by            String?   @db.Char(36)
  resend_count          Int       @default(0)
  last_sent_at          DateTime?
  created_at            DateTime  @default(now())
  updated_at            DateTime  @updatedAt
  clinic                clinics   @relation(fields: [clinic_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
  user                  users?    @relation("invitation_user", fields: [user_id], references: [id], onDelete: SetNull, onUpdate: Cascade)
  inviter               users?    @relation("invitation_inviter", fields: [invited_by], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([clinic_id, status, expires_at])
  @@index([clinic_id, email, status])
  @@index([invited_by])
  @@index([user_id])
}

model subscription_plans {
  id             String                 @id @db.Char(36)
  code           String                 @unique @db.VarChar(100)
  name           String                 @db.VarChar(190)
  status         String                 @default("ACTIVE") @db.VarChar(40)
  price_cents    Int                    @default(0)
  currency       String                 @default("USD") @db.Char(3)
  trial_days     Int                    @default(14)
  limits         Json?
  features       Json?
  is_system      Boolean                @default(false)
  created_at     DateTime               @default(now())
  updated_at     DateTime               @updatedAt
  subscriptions  clinic_subscriptions[]

  @@index([status])
}

model clinic_subscriptions {
  id                      String             @id @db.Char(36)
  clinic_id               String             @db.Char(36)
  plan_id                 String             @db.Char(36)
  status                  String             @default("TRIALING") @db.VarChar(40)
  starts_at               DateTime           @default(now())
  ends_at                 DateTime?
  trial_ends_at           DateTime?
  active_subscription_key String?            @unique @db.VarChar(120)
  metadata                Json?
  created_by              String?            @db.Char(36)
  updated_by              String?            @db.Char(36)
  deleted_by              String?            @db.Char(36)
  is_deleted              Boolean            @default(false)
  created_at              DateTime           @default(now())
  updated_at              DateTime           @updatedAt
  deleted_at              DateTime?
  clinic                  clinics            @relation(fields: [clinic_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
  plan                    subscription_plans @relation(fields: [plan_id], references: [id], onDelete: Restrict, onUpdate: Cascade)
  creator                 users?             @relation("subscription_created_by", fields: [created_by], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([clinic_id, is_deleted])
  @@index([clinic_id, updated_at])
  @@index([clinic_id, status, ends_at])
  @@index([plan_id])
}

model users {
  id            String    @id @db.Char(36)
  clinic_id     String?   @db.Char(36)
  full_name     String    @db.VarChar(190)
  email         String    @db.VarChar(190)
  login_scope   String    @default("PLATFORM") @db.VarChar(190)
  phone         String?   @db.VarChar(40)
  password_hash String    @db.VarChar(255)
  user_type     String    @db.VarChar(40)
  status        String    @default("PENDING") @db.VarChar(40)
  token_version Int       @default(0)
  last_login_at DateTime?
  profile       Json?
  created_by    String?   @db.Char(36)
  updated_by    String?   @db.Char(36)
  deleted_by    String?   @db.Char(36)
  is_deleted    Boolean   @default(false)
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt
  deleted_at    DateTime?
  refresh_tokens refresh_tokens[]
  password_reset_tokens password_reset_tokens[]
  login_attempts login_attempts[]
  account_lockouts account_lockouts[]
  user_roles user_roles[]
  branch_assignments user_branch_assignments[]
  clinic clinics? @relation("clinic_users", fields: [clinic_id], references: [id], onDelete: Restrict, onUpdate: Cascade)
  owned_clinics clinics[] @relation("clinic_owner")
  settings settings[] @relation("user_settings")
  setting_history_changes setting_history[] @relation("setting_changed_by")
  invitations user_invitations[] @relation("invitation_user")
  sent_invitations user_invitations[] @relation("invitation_inviter")
  subscription_creations clinic_subscriptions[] @relation("subscription_created_by")

  @@unique([clinic_id, email])
  @@unique([login_scope, email])
  @@index([clinic_id])
  @@index([clinic_id, is_deleted])
  @@index([clinic_id, created_at])
  @@index([clinic_id, updated_at])
  @@index([clinic_id, status, is_deleted])
  @@index([email])
  @@index([token_version])
}

model permissions {
  id               String             @id @db.Char(36)
  permission_key   String             @unique @db.VarChar(160)
  module_name      String             @db.VarChar(80)
  action           String             @db.VarChar(80)
  description      String?            @db.VarChar(500)
  is_system        Boolean            @default(true)
  created_at       DateTime           @default(now())
  updated_at       DateTime           @updatedAt
  role_permissions role_permissions[]

  @@index([module_name, action])
}

model roles {
  id               String             @id @db.Char(36)
  clinic_id        String?            @db.Char(36)
  scope_key        String             @db.VarChar(190)
  code             String             @db.VarChar(100)
  name             String             @db.VarChar(190)
  description      String?            @db.VarChar(500)
  is_system        Boolean            @default(false)
  is_platform      Boolean            @default(false)
  created_by       String?            @db.Char(36)
  updated_by       String?            @db.Char(36)
  deleted_by       String?            @db.Char(36)
  is_deleted       Boolean            @default(false)
  created_at       DateTime           @default(now())
  updated_at       DateTime           @updatedAt
  deleted_at       DateTime?
  role_permissions role_permissions[]
  user_roles       user_roles[]
  clinic           clinics?           @relation("clinic_roles", fields: [clinic_id], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([scope_key, code])
  @@index([clinic_id])
  @@index([clinic_id, is_deleted])
  @@index([clinic_id, created_at])
  @@index([clinic_id, updated_at])
  @@index([clinic_id, is_system, is_deleted])
  @@index([scope_key])
}

model role_permissions {
  id            String      @id @db.Char(36)
  clinic_id     String?     @db.Char(36)
  role_id       String      @db.Char(36)
  permission_id String      @db.Char(36)
  scope         String      @default("CLINIC") @db.VarChar(40)
  created_by    String?     @db.Char(36)
  updated_by    String?     @db.Char(36)
  deleted_by    String?     @db.Char(36)
  is_deleted    Boolean     @default(false)
  created_at    DateTime    @default(now())
  updated_at    DateTime    @updatedAt
  deleted_at    DateTime?
  role          roles       @relation(fields: [role_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
  permission    permissions @relation(fields: [permission_id], references: [id], onDelete: Restrict, onUpdate: Cascade)
  clinic        clinics?    @relation("clinic_role_permissions", fields: [clinic_id], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([role_id, permission_id, scope])
  @@index([clinic_id])
  @@index([clinic_id, is_deleted])
  @@index([clinic_id, created_at])
  @@index([clinic_id, updated_at])
  @@index([permission_id])
}

model user_roles {
  id          String    @id @db.Char(36)
  clinic_id   String?   @db.Char(36)
  user_id     String    @db.Char(36)
  role_id     String    @db.Char(36)
  active_assignment_key String? @unique @db.VarChar(140)
  assigned_by String?   @db.Char(36)
  revoked_at  DateTime?
  revoked_by  String?   @db.Char(36)
  created_by  String?   @db.Char(36)
  updated_by  String?   @db.Char(36)
  deleted_by  String?   @db.Char(36)
  is_deleted  Boolean   @default(false)
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt
  deleted_at  DateTime?
  user        users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
  role        roles     @relation(fields: [role_id], references: [id], onDelete: Restrict, onUpdate: Cascade)
  clinic      clinics?  @relation("clinic_user_roles", fields: [clinic_id], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([clinic_id])
  @@index([clinic_id, is_deleted])
  @@index([clinic_id, created_at])
  @@index([clinic_id, updated_at])
  @@index([clinic_id, user_id, is_deleted])
  @@index([clinic_id, user_id, role_id, is_deleted, revoked_at])
  @@index([user_id, is_deleted])
  @@index([role_id, is_deleted])
}

model user_branch_assignments {
  id          String    @id @db.Char(36)
  clinic_id   String    @db.Char(36)
  user_id     String    @db.Char(36)
  branch_id   String    @db.Char(36)
  is_primary  Boolean   @default(false)
  active_assignment_key String? @unique @db.VarChar(180)
  active_primary_assignment_key String? @unique @db.VarChar(180)
  assigned_by String?   @db.Char(36)
  revoked_at  DateTime?
  revoked_by  String?   @db.Char(36)
  created_by  String?   @db.Char(36)
  updated_by  String?   @db.Char(36)
  deleted_by  String?   @db.Char(36)
  is_deleted  Boolean   @default(false)
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt
  deleted_at  DateTime?
  user        users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
  clinic      clinics   @relation(fields: [clinic_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
  branch      clinic_branches @relation(fields: [branch_id], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([clinic_id])
  @@index([clinic_id, is_deleted])
  @@index([clinic_id, created_at])
  @@index([clinic_id, updated_at])
  @@index([clinic_id, user_id, is_deleted])
  @@index([clinic_id, branch_id, is_deleted])
}

model refresh_tokens {
  id                   String    @id @db.Char(36)
  clinic_id            String?   @db.Char(36)
  user_id              String    @db.Char(36)
  session_id           String    @db.Char(36)
  token_hash           String    @db.Char(64)
  device_info          Json?
  ip_address           String?   @db.VarChar(64)
  user_agent           String?   @db.VarChar(512)
  status               String    @default("ACTIVE") @db.VarChar(40)
  expires_at           DateTime
  last_used_at         DateTime?
  revoked_at           DateTime?
  replaced_by_token_id String?   @db.Char(36)
  created_at           DateTime  @default(now())
  updated_at           DateTime  @updatedAt
  user                 users     @relation(fields: [user_id], references: [id], onDelete: Restrict, onUpdate: Cascade)
  clinic               clinics?  @relation("clinic_refresh_tokens", fields: [clinic_id], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([token_hash])
  @@index([clinic_id, user_id, expires_at])
  @@index([user_id, status, revoked_at])
  @@index([session_id])
  @@index([expires_at])
}

model password_reset_tokens {
  id         String    @id @db.Char(36)
  clinic_id  String?   @db.Char(36)
  user_id    String    @db.Char(36)
  token_hash String    @db.Char(64)
  expires_at DateTime
  used_at    DateTime?
  created_at DateTime  @default(now())
  user       users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
  clinic     clinics?  @relation("clinic_password_reset_tokens", fields: [clinic_id], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([token_hash])
  @@index([clinic_id, user_id, expires_at])
  @@index([expires_at])
}

model login_attempts {
  id             String   @id @db.Char(36)
  clinic_id      String?  @db.Char(36)
  email          String   @db.VarChar(190)
  user_id        String?  @db.Char(36)
  ip_address     String   @db.VarChar(64)
  user_agent     String?  @db.VarChar(512)
  success        Boolean
  failure_reason String?  @db.VarChar(160)
  attempted_at   DateTime @default(now())
  user           users?   @relation(fields: [user_id], references: [id], onDelete: SetNull, onUpdate: Cascade)
  clinic         clinics? @relation("clinic_login_attempts", fields: [clinic_id], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([clinic_id, email, attempted_at])
  @@index([ip_address, attempted_at])
  @@index([user_id, attempted_at])
}

model account_lockouts {
  id            String    @id @db.Char(36)
  clinic_id     String?   @db.Char(36)
  user_id       String?   @db.Char(36)
  email         String    @db.VarChar(190)
  ip_address    String?   @db.VarChar(64)
  reason        String    @db.VarChar(160)
  locked_until  DateTime
  unlocked_at   DateTime?
  created_at    DateTime  @default(now())
  user          users?    @relation(fields: [user_id], references: [id], onDelete: SetNull, onUpdate: Cascade)
  clinic        clinics?  @relation("clinic_account_lockouts", fields: [clinic_id], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([clinic_id, email, locked_until])
  @@index([user_id, locked_until])
  @@index([ip_address, locked_until])
}

model outbox_events {
  id             String    @id @db.Char(36)
  event_name     String    @db.VarChar(160)
  event_version  String    @db.VarChar(20)
  aggregate_type String    @db.VarChar(120)
  aggregate_id   String    @db.Char(36)
  tenant_id      String?   @db.Char(36)
  correlation_id String?   @db.Char(36)
  causation_id   String?   @db.Char(36)
  producer       String    @db.VarChar(120)
  payload        Json
  status         String    @default("PENDING") @db.VarChar(40)
  attempts       Int       @default(0)
  next_retry_at  DateTime?
  published_at   DateTime?
  last_error     String?   @db.VarChar(1000)
  created_at     DateTime  @default(now())
  updated_at     DateTime  @updatedAt

  @@index([tenant_id, status, next_retry_at])
  @@index([status, next_retry_at])
  @@index([aggregate_type, aggregate_id])
  @@index([correlation_id])
}

model processed_events {
  id            String   @id @db.Char(36)
  event_id      String   @db.Char(36)
  consumer_name String   @db.VarChar(160)
  status        String   @default("PROCESSED") @db.VarChar(40)
  processed_at  DateTime @default(now())
  metadata      Json?

  @@unique([event_id, consumer_name])
  @@index([consumer_name, processed_at])
}

model jobs {
  id              String    @id @db.Char(36)
  clinic_id       String?   @db.Char(36)
  job_type        String    @db.VarChar(120)
  status          String    @default("QUEUED") @db.VarChar(40)
  priority        String    @default("NORMAL") @db.VarChar(30)
  payload         Json
  attempts        Int       @default(0)
  max_attempts    Int       @default(5)
  run_at          DateTime  @default(now())
  locked_by       String?   @db.VarChar(120)
  locked_at       DateTime?
  completed_at    DateTime?
  last_error      String?   @db.VarChar(1000)
  idempotency_key String?   @db.VarChar(190)
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt
  attempts_log    job_attempts[]
  dead_letters    dead_letter_jobs[]

  @@unique([idempotency_key])
  @@index([status, run_at])
  @@index([clinic_id, status, run_at])
  @@index([locked_at])
}

model job_attempts {
  id             String    @id @db.Char(36)
  job_id         String    @db.Char(36)
  clinic_id      String?   @db.Char(36)
  attempt_number Int
  status         String    @db.VarChar(40)
  started_at     DateTime  @default(now())
  finished_at    DateTime?
  error_message  String?   @db.VarChar(1000)
  metadata       Json?
  job            jobs      @relation(fields: [job_id], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([job_id, attempt_number])
  @@index([clinic_id, job_id])
  @@index([status])
}

model dead_letter_jobs {
  id               String    @id @db.Char(36)
  job_id           String    @db.Char(36)
  clinic_id        String?   @db.Char(36)
  failure_reason   String    @db.VarChar(1000)
  payload          Json
  failed_at        DateTime  @default(now())
  resolved_at      DateTime?
  resolution_notes String?   @db.VarChar(1000)
  job              jobs      @relation(fields: [job_id], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([clinic_id, failed_at])
  @@index([resolved_at])
}

model dead_letter_events {
  id              String    @id @db.Char(36)
  outbox_event_id String?   @db.Char(36)
  tenant_id       String?   @db.Char(36)
  event_name      String    @db.VarChar(160)
  payload         Json
  failure_reason  String    @db.VarChar(1000)
  failed_at       DateTime  @default(now())
  resolved_at     DateTime?

  @@index([tenant_id, failed_at])
  @@index([event_name])
  @@index([resolved_at])
}
