APP_NAME=doctor-system-backend-new
NODE_ENV=development
PORT=8080
# Integer number of trusted proxies. Use 0 for local development.
TRUST_PROXY=0
# Comma-separated http/https origins. Wildcards are rejected.
CORS_ALLOWED_ORIGINS=http://localhost:5173
JSON_BODY_LIMIT=1mb
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
AUTH_LOGIN_RATE_LIMIT_WINDOW_MS=900000
AUTH_LOGIN_RATE_LIMIT_MAX=10
AUTH_REFRESH_RATE_LIMIT_WINDOW_MS=900000
AUTH_REFRESH_RATE_LIMIT_MAX=60
AUTH_LOCKOUT_MAX_FAILURES=5
AUTH_LOCKOUT_WINDOW_MS=900000
AUTH_LOCKOUT_DURATION_MS=900000
JWT_ACCESS_SECRET=replace-with-at-least-32-random-characters
JWT_REFRESH_SECRET=replace-with-another-32-random-characters
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=2592000
# Local HTTP development can use false. Production must use true or startup fails.
AUTH_COOKIE_SECURE=false
# Sprint 1 exposes Auth only by default. Enable only after the RBAC/User sprint is accepted.
ENABLE_POST_SPRINT_1_ROUTES=false
# Required. Must be a mysql:// URL.
DATABASE_URL=mysql://user:password@localhost:3306/doctor_system
SENTRY_DSN=
