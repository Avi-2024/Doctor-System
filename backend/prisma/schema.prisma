generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model schema_migrations {
  name        String   @id
  executed_at DateTime @default(now())
}

model clinics {
  id         String   @id
  clinic_id String?
  name       String
  code       String
  status     String   @default("ACTIVE")
  contact    Json?
  address    Json?
  branding   Json?
  timezone   String   @default("Asia/Kolkata")
  created_by String?
  updated_by String?
  is_deleted Boolean  @default(false)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([clinic_id, status, is_deleted])
}

model users {
  id                 String    @id
  clinic_id          String?
  full_name          String
  email              String
  phone              String?
  password_hash      String
  refresh_token_hash String?
  role               String
  permissions        Json
  profile            Json?
  is_active          Boolean   @default(true)
  last_login_at      DateTime?
  created_by         String?
  updated_by         String?
  is_deleted         Boolean   @default(false)
  created_at         DateTime  @default(now())
  updated_at         DateTime  @updatedAt

  @@index([clinic_id, role, is_active, is_deleted])
}

model refresh_tokens {
  id                   String    @id
  clinic_id            String?
  user_id              String
  token_hash           String    @unique
  expires_at           DateTime
  revoked_at           DateTime?
  replaced_by_token_id String?
  created_by           String?
  updated_by           String?
  is_deleted           Boolean   @default(false)
  created_at           DateTime  @default(now())
  updated_at           DateTime  @updatedAt

  @@index([clinic_id, user_id, expires_at])
}

model password_reset_tokens {
  id          String    @id
  clinic_id   String?
  user_id     String
  token_hash  String    @unique
  expires_at  DateTime
  consumed_at DateTime?
  created_by  String?
  updated_by  String?
  is_deleted  Boolean   @default(false)
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt

  @@index([clinic_id, user_id, expires_at])
}

model clinic_branches {
  id         String   @id
  clinic_id String
  name       String
  contact    Json?
  address    Json?
  is_primary Boolean  @default(false)
  is_active  Boolean  @default(true)
  created_by String?
  updated_by String?
  is_deleted Boolean  @default(false)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([clinic_id, is_active, is_deleted])
}

model patients {
  id              String    @id
  clinic_id       String
  patient_code    String
  full_name       String
  phone           String
  email           String?
  gender          String    @default("UNKNOWN")
  date_of_birth   DateTime?
  blood_group     String?
  demographics    Json?
  medical_summary Json?
  created_by      String?
  updated_by      String?
  is_deleted      Boolean   @default(false)
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  @@index([clinic_id, phone, full_name, is_deleted])
}

model doctor_schedules {
  id              String   @id
  clinic_id       String
  doctor_id       String
  branch_id       String?
  weekly_schedule Json
  timezone        String   @default("Asia/Kolkata")
  is_active       Boolean  @default(true)
  created_by      String?
  updated_by      String?
  is_deleted      Boolean  @default(false)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  @@index([clinic_id, doctor_id, is_active, is_deleted])
}

model doctor_leaves {
  id         String   @id
  clinic_id  String
  doctor_id  String
  starts_at  DateTime
  ends_at    DateTime
  reason     String?
  status     String   @default("APPROVED")
  created_by String?
  updated_by String?
  is_deleted Boolean  @default(false)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([clinic_id, doctor_id, starts_at, ends_at, is_deleted])
}

model patient_records {
  id          String   @id
  clinic_id   String
  patient_id  String
  record_type String
  record_data Json
  created_by  String?
  updated_by  String?
  is_deleted  Boolean  @default(false)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@index([clinic_id, patient_id, record_type, is_deleted])
}

model appointments {
  id                  String    @id
  clinic_id           String
  patient_id          String
  doctor_id           String
  branch_id           String?
  appointment_date    DateTime
  start_time          String
  end_time            String
  status              String    @default("SCHEDULED")
  source              String    @default("WALKIN")
  reason              String?
  cancellation_reason String?
  created_by          String?
  updated_by          String?
  is_deleted          Boolean   @default(false)
  created_at          DateTime  @default(now())
  updated_at          DateTime  @updatedAt

  @@index([clinic_id, doctor_id, appointment_date, status, is_deleted])
  @@index([clinic_id, patient_id, appointment_date, is_deleted])
}

model queue_entries {
  id             String    @id
  clinic_id      String
  patient_id     String
  doctor_id      String
  appointment_id String?
  queue_date     DateTime
  token_number   Int
  priority       Int       @default(0)
  status         String    @default("WAITING")
  called_at      DateTime?
  completed_at   DateTime?
  created_by     String?
  updated_by     String?
  is_deleted     Boolean   @default(false)
  created_at     DateTime  @default(now())
  updated_at     DateTime  @updatedAt

  @@index([clinic_id, doctor_id, queue_date, status, is_deleted])
}

model queue_counters {
  id          String   @id
  clinic_id   String
  queue_date  DateTime
  next_token  Int      @default(1)
  created_by  String?
  updated_by  String?
  is_deleted  Boolean  @default(false)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@unique([clinic_id, queue_date])
  @@index([clinic_id, queue_date, is_deleted])
}

model consultations {
  id             String   @id
  clinic_id      String
  patient_id     String
  doctor_id      String
  appointment_id String?
  status         String   @default("DRAFT")
  clinical_data  Json
  created_by     String?
  updated_by     String?
  is_deleted     Boolean  @default(false)
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  @@index([clinic_id, patient_id, created_at, is_deleted])
}

model vitals {
  id              String   @id
  clinic_id       String
  patient_id      String
  consultation_id String?
  vital_data      Json
  created_by      String?
  updated_by      String?
  is_deleted      Boolean  @default(false)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  @@index([clinic_id, patient_id, created_at, is_deleted])
}

model prescriptions {
  id              String   @id
  clinic_id       String
  patient_id      String
  doctor_id       String
  consultation_id String?
  diagnosis       String?
  medicines       Json
  advice          String?
  created_by      String?
  updated_by      String?
  is_deleted      Boolean  @default(false)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  @@index([clinic_id, patient_id, created_at, is_deleted])
}

model prescription_templates {
  id            String   @id
  clinic_id     String
  doctor_id     String
  name          String
  template_data Json
  created_by    String?
  updated_by    String?
  is_deleted    Boolean  @default(false)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  @@index([clinic_id, doctor_id, name, is_deleted])
}

model lab_tests {
  id         String   @id
  clinic_id  String
  code       String
  name       String
  category   String?
  price      Float    @default(0)
  is_active  Boolean  @default(true)
  created_by String?
  updated_by String?
  is_deleted Boolean  @default(false)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
}

model lab_orders {
  id                   String   @id
  clinic_id            String
  order_number         String
  patient_id           String
  doctor_id            String
  status               String   @default("ORDERED")
  items                Json
  report_attachment_id String?
  created_by           String?
  updated_by           String?
  is_deleted           Boolean  @default(false)
  created_at           DateTime @default(now())
  updated_at           DateTime @updatedAt

  @@index([clinic_id, patient_id, created_at, is_deleted])
}

model lab_order_items {
  id           String   @id
  clinic_id    String
  lab_order_id String
  lab_test_id  String?
  test_name    String
  price        Float    @default(0)
  status       String   @default("ORDERED")
  result_data  Json?
  created_by   String?
  updated_by   String?
  is_deleted   Boolean  @default(false)
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  @@index([clinic_id, lab_order_id, status, is_deleted])
}

model lab_reports {
  id           String    @id
  clinic_id    String
  lab_order_id String
  patient_id   String
  attachment_id String
  result_data  Json?
  reviewed_by  String?
  reviewed_at  DateTime?
  created_by   String?
  updated_by   String?
  is_deleted   Boolean   @default(false)
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt

  @@index([clinic_id, patient_id, created_at, is_deleted])
}

model invoices {
  id             String   @id
  clinic_id      String
  invoice_number String
  patient_id     String?
  subtotal       Float
  discount       Float    @default(0)
  tax            Float    @default(0)
  total_amount   Float
  paid_amount    Float    @default(0)
  due_amount     Float
  status         String   @default("UNPAID")
  items          Json
  created_by     String?
  updated_by     String?
  is_deleted     Boolean  @default(false)
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  @@index([clinic_id, status, created_at, is_deleted])
}

model invoice_items {
  id           String   @id
  clinic_id    String
  invoice_id   String
  description  String
  quantity     Float
  unit_price   Float
  total_amount Float
  created_by   String?
  updated_by   String?
  is_deleted   Boolean  @default(false)
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  @@index([clinic_id, invoice_id, is_deleted])
}

model payments {
  id               String   @id
  clinic_id        String
  invoice_id       String
  receipt_number   String
  amount           Float
  method           String
  reference_number String?
  paid_at          DateTime @default(now())
  created_by       String?
  updated_by       String?
  is_deleted       Boolean  @default(false)
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  @@index([clinic_id, invoice_id, paid_at, is_deleted])
}

model attachments {
  id         String   @id
  clinic_id  String
  owner_type String
  owner_id   String?
  file_name  String
  mime_type  String
  size_bytes Int
  bucket     String
  object_key String
  created_by String?
  updated_by String?
  is_deleted Boolean  @default(false)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([clinic_id, owner_type, owner_id, is_deleted])
}

model notifications {
  id                  String    @id
  clinic_id           String
  channel             String
  recipient           String
  message             String
  payload             Json?
  status              String    @default("QUEUED")
  scheduled_for       DateTime?
  provider_message_id String?
  attempts            Int       @default(0)
  last_error          String?
  created_by          String?
  updated_by          String?
  is_deleted          Boolean   @default(false)
  created_at          DateTime  @default(now())
  updated_at          DateTime  @updatedAt

  @@index([clinic_id, channel, status, scheduled_for, is_deleted])
  @@index([status, updated_at, attempts, is_deleted])
}

model whatsapp_accounts {
  id                   String   @id
  clinic_id            String
  phone_number_id      String
  business_account_id  String
  display_phone_number String
  is_active            Boolean  @default(true)
  created_by           String?
  updated_by           String?
  is_deleted           Boolean  @default(false)
  created_at           DateTime @default(now())
  updated_at           DateTime @updatedAt

  @@index([clinic_id, is_active, is_deleted])
}

model whatsapp_messages {
  id                  String   @id
  clinic_id           String
  notification_id     String?
  patient_id          String?
  direction           String
  sender              String
  recipient           String
  message_type        String   @default("TEXT")
  message_body        String?
  provider_message_id String?
  status              String
  payload             Json?
  created_by          String?
  updated_by          String?
  is_deleted          Boolean  @default(false)
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt

  @@index([clinic_id, patient_id, created_at, is_deleted])
}

model whatsapp_templates {
  id                     String   @id
  clinic_id              String
  name                   String
  provider_template_name String
  language_code          String   @default("en_US")
  category               String   @default("UTILITY")
  status                 String   @default("DRAFT")
  components             Json
  created_by             String?
  updated_by             String?
  is_deleted             Boolean  @default(false)
  created_at             DateTime @default(now())
  updated_at             DateTime @updatedAt

  @@index([clinic_id, status, category, is_deleted])
}

model subscription_plans {
  id            String   @id
  clinic_id     String?
  code          String
  name          String
  monthly_price Float    @default(0)
  yearly_price  Float    @default(0)
  limits        Json
  features      Json
  created_by    String?
  updated_by    String?
  is_deleted    Boolean  @default(false)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt
}

model clinic_subscriptions {
  id         String    @id
  clinic_id  String
  plan_id    String
  status     String    @default("TRIAL")
  starts_at  DateTime
  ends_at    DateTime?
  usage_data Json
  created_by String?
  updated_by String?
  is_deleted Boolean   @default(false)
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt

  @@index([clinic_id, status, starts_at, ends_at, is_deleted])
}

model audit_logs {
  id            String   @id
  clinic_id     String?
  actor_user_id String?
  action        String
  module_name   String
  entity_type   String
  entity_id     String?
  request_id    String?
  before_data   Json?
  after_data    Json?
  metadata      Json?
  created_by    String?
  updated_by    String?
  is_deleted    Boolean  @default(false)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  @@index([clinic_id, module_name, action, created_at])
}

model settings {
  id            String   @id
  clinic_id     String?
  setting_key   String
  setting_value Json?
  scope         String   @default("CLINIC")
  is_encrypted  Boolean  @default(false)
  created_by    String?
  updated_by    String?
  is_deleted    Boolean  @default(false)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  @@index([clinic_id, scope, is_deleted])
}

model user_invitations {
  id          String    @id
  clinic_id   String
  email       String
  full_name   String
  phone       String?
  role        String
  permissions Json
  token_hash  String    @unique
  expires_at  DateTime
  accepted_at DateTime?
  revoked_at  DateTime?
  invited_by  String
  created_by  String?
  updated_by  String?
  is_deleted  Boolean   @default(false)
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt

  @@index([clinic_id, email, expires_at, is_deleted])
  @@index([clinic_id, accepted_at, revoked_at, expires_at, is_deleted])
}
