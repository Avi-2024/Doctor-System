# Runtime
NODE_ENV=development
APP_NAME=doctor-system-backend
PORT=8080
TRUST_PROXY=0
CORS_ALLOWED_ORIGINS=http://localhost:5173

# MySQL
DATABASE_URL=mysql://doctor_app:replace-me@127.0.0.1:3306/doctor_system
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=doctor_system
MYSQL_USER=doctor_app
MYSQL_PASSWORD=replace-me
MYSQL_CONNECTION_LIMIT=20
MYSQL_TEST_HOST=127.0.0.1
MYSQL_TEST_PORT=3306
MYSQL_TEST_DATABASE=doctor_system_test
MYSQL_TEST_USER=doctor_test
MYSQL_TEST_PASSWORD=replace-me

# Authentication
JWT_ACCESS_SECRET=replace-with-64-character-access-secret
JWT_REFRESH_SECRET=replace-with-64-character-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
PASSWORD_RESET_WEB_URL=http://localhost:5173/auth/reset-password
PASSWORD_RESET_WEBHOOK_URL=
PASSWORD_RESET_WEBHOOK_SECRET=
USER_INVITATION_WEB_URL=http://localhost:5173/auth/accept-invitation
USER_INVITATION_WEBHOOK_URL=
USER_INVITATION_WEBHOOK_SECRET=
USER_INVITATION_TTL_HOURS=72

# Security
SETTINGS_ENCRYPTION_KEY=replace-with-32-plus-character-key
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_MAX=20
JSON_BODY_LIMIT=1mb
NOTIFICATION_BATCH_SIZE=50
NOTIFICATION_MAX_ATTEMPTS=5
NOTIFICATION_RETRY_BASE_SECONDS=30
NOTIFICATION_PROCESSING_TIMEOUT_SECONDS=300
NOTIFICATION_POLL_INTERVAL_MS=5000

# Bootstrap
SUPER_ADMIN_NAME=
SUPER_ADMIN_EMAIL=
SUPER_ADMIN_PASSWORD=

# AWS S3
AWS_REGION=ap-south-1
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_SIGNED_URL_EXPIRES_SECONDS=300
UPLOAD_MAX_FILE_SIZE_BYTES=10485760
UPLOAD_ALLOWED_MIME_TYPES=application/pdf,image/jpeg,image/png,image/webp

# Meta WhatsApp
WHATSAPP_API_BASE_URL=https://graph.facebook.com/v21.0
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=

# Observability
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.05
