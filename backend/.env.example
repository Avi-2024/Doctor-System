# App
NODE_ENV=production
PORT=8080
APP_NAME=doctor-system-backend
API_BASE_URL=https://api.yourdomain.com
APP_MODE=single_clinic

# MongoDB
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>/<db>?retryWrites=true&w=majority
MONGODB_DB_NAME=doctor_system_prod

# JWT
# Generate with: node -e "require('crypto').randomBytes(48).toString('hex')|console.log"
JWT_ACCESS_SECRET=<64+_char_random_secret>
JWT_REFRESH_SECRET=<different_64+_char_random_secret>
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Auth Cookies (set by server automatically — HttpOnly, Secure, SameSite)
# access_token  — maxAge = JWT_ACCESS_EXPIRES_IN
# refresh_token — maxAge = JWT_REFRESH_EXPIRES_IN
# In production: NODE_ENV=production → secure: true, sameSite: strict
# In development: NODE_ENV=development → secure: false, sameSite: lax

# WhatsApp Business API
WHATSAPP_API_BASE_URL=https://graph.facebook.com/v21.0
WHATSAPP_PHONE_NUMBER_ID=<phone_number_id>
WHATSAPP_BUSINESS_ACCOUNT_ID=<waba_id>
WHATSAPP_ACCESS_TOKEN=<long_lived_access_token>
WHATSAPP_WEBHOOK_VERIFY_TOKEN=<verify_token>

# Razorpay
RAZORPAY_KEY_ID=<razorpay_key_id>
RAZORPAY_KEY_SECRET=<razorpay_key_secret>
RAZORPAY_WEBHOOK_SECRET=<razorpay_webhook_secret>

# File Storage
STORAGE_DRIVER=local
LOCAL_STORAGE_PATH=./uploads
FILE_BASE_URL=http://localhost:8080/files

# AWS S3 (when STORAGE_DRIVER=s3)
AWS_REGION=ap-south-1
AWS_S3_BUCKET=<bucket_name>
AWS_ACCESS_KEY_ID=<access_key>
AWS_SECRET_ACCESS_KEY=<secret_key>
AWS_S3_PUBLIC_BASE_URL=https://<bucket>.s3.<region>.amazonaws.com

# Security / Ops
CORS_ALLOWED_ORIGINS=https://app.yourdomain.com,https://admin.yourdomain.com
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
LOG_LEVEL=info
